# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar   # keep the wrapper JAR committed

# Gradle configuration cache
.gradle/configuration-cache/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── Eclipse ───────────────────────────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Linux / general ───────────────────────────────────────────────────────────
*~
*.swp
*.bak

# ── Java compiled output ───────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
hs_err_pid*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
gc.log

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
*.env

# ── Test / coverage reports ───────────────────────────────────────────────────
# (under build/ so already covered above, but explicit for clarity)
app/build/reports/

# ── AOT cache files ───────────────────────────────────────────────────────────
*.aotconf
*.aot
